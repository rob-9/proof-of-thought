{
  "name": "@canteen/pot",
  "version": "0.1.0",
  "description": "Proof of Thought (PoT) — verifiable agent reasoning provenance for Solana. Canonicalization + commitment layer.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./canonical": {
      "types": "./dist/canonical/index.d.ts",
      "import": "./dist/canonical/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "@solana/web3.js": "^1.95.0",
    "cbor2": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
